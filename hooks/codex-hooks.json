{
  "description": "pi-esr + pi-loom hooks — injects ESR state, [PI_LOOM] memory index, enforces session protocol, and auto-captures tool results",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"$($SHELL -lc 'echo $PATH' 2>/dev/null):$PATH\"; _R=\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT:-}}\"; [ -n \"$_R\" ] || { _C=\"${CODEX_CONFIG_DIR:-$HOME/.codex}\"; _R=$(ls -dt \"$_C/plugins/cache/pi-esr\"/[0-9]*/ \"$_C/plugins/marketplaces/pi-esr/plugin\" 2>/dev/null | while IFS= read -r d; do d=\"${d%/}\"; [ -f \"$d/dist/hook-context.js\" ] && { printf '%s\\n' \"$d\"; break; }; done); }; [ -n \"$_R\" ] && node \"$_R/dist/hook-context.js\" || { echo '{\"continue\":true,\"suppressOutput\":true}'; exit 0; }",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT}}\"/scripts/inject-loom-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT}}\"/scripts/protocol-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT}}\"/scripts/auto-capture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "loom_status|loom_recall",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT}}\"/scripts/unlock-protocol.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT}}\"/scripts/auto-capture.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT}}\"/scripts/session-cleanup.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

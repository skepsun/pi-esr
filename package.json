{
  "name": "pi-esr",
  "version": "0.3.0",
  "description": "ESR (Engineering State Runtime) - constrained semantic graph state machine plugin for Pi agent",
  "keywords": [
    "pi-package",
    "pi-esr",
    "esr",
    "state-machine",
    "semantic-graph"
  ],
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run tests/",
    "test:core": "vitest run packages/core/tests/",
    "test:mcp": "vitest run packages/adapter-mcp/tests/",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "build": "tsc && npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.16.2",
    "@types/better-sqlite3": "^7.6.0",
    "better-sqlite3": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}

{
  "name": "pi-esr",
  "version": "0.2.0",
  "description": "ESR (Engineering State Runtime) - constrained semantic graph state machine plugin for Pi agent",
  "keywords": [
    "pi-package",
    "pi-esr",
    "esr",
    "state-machine",
    "semantic-graph"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}

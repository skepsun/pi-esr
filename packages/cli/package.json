{
  "name": "pi-esr",
  "version": "0.3.0",
  "description": "ESR (Engineering State Runtime) — constrained semantic graph state machine. One install, all agents.",
  "type": "module",
  "bin": {
    "pi-esr": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/cli.d.ts",
    "dist/cli.js",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/setup.d.ts",
    "dist/setup.js",
    "prompts/esr.md",
    ".claude-plugin/plugin.json",
    ".claude-plugin/marketplace.json",
    ".codex-plugin/plugin.json",
    ".mcp.json",
    "marketplace.json",
    ".agents/plugins/marketplace.json",
    "skills/esr/SKILL.md",
    "assets/pi-esr.svg",
    "plugins/pi-esr/.codex-plugin/plugin.json",
    "plugins/pi-esr/skills/esr/SKILL.md",
    "plugins/pi-esr/assets/pi-esr.svg",
    "plugins/pi-esr/.mcp.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && mkdir -p plugins/pi-esr && cp -r ../../.codex-plugin plugins/pi-esr/ && cp -r ../../skills plugins/pi-esr/ && cp -r ../../assets plugins/pi-esr/ && cp ../../.mcp.json plugins/pi-esr/",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"console.log('\\n✨ pi-esr installed! Run: pi-esr plugin install\\n')\""
  },
  "dependencies": {
    "@pi-esr/adapter-mcp": "0.3.0",
    "@pi-esr/adapter-opencode": "0.3.0",
    "@pi-esr/core": "0.3.0",
    "pi-esr": "file:"
  },
  "keywords": [
    "esr",
    "state-machine",
    "semantic-graph",
    "mcp",
    "claude-code",
    "cursor",
    "opencode"
  ],
  "license": "MIT"
}

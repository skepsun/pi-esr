{
  "name": "pi-esr",
  "version": "0.3.0",
  "description": "ESR (Engineering State Runtime) — constrained semantic graph state machine. One install, all agents.",
  "type": "module",
  "bin": {
    "pi-esr": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "prompts"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"console.log('\\n✨ pi-esr installed! Run: pi-esr setup\\n')\""
  },
  "dependencies": {
    "@pi-esr/adapter-mcp": "0.3.0",
    "@pi-esr/adapter-opencode": "0.3.0",
    "@pi-esr/core": "0.3.0"
  },
  "keywords": ["esr", "state-machine", "semantic-graph", "mcp", "claude-code", "cursor", "opencode"],
  "license": "MIT"
}
